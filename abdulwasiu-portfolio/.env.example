# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
APP_NAME=abdulwasiu-portfolio

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:4000/api/v1
VITE_SITE_URL=http://localhost:5173

# ── Backend ───────────────────────────────────────────────────────────────────
PORT=4000
API_VERSION=v1
API_PREFIX=/api/v1

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/portfolio_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=portfolio_db

# ── Email (Nodemailer) ────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.fi
SMTP_PASS=your-app-password
CONTACT_EMAIL_TO=abdulwasiu@example.fi

# ── Security ─────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
CORS_ORIGINS=http://localhost:5173,https://abdulwasiu.dev
