# Environment variables store anything that might change within an environment 
# or between environments (development, staging, production). 
# This includes things like API keys, database connection strings, and configuration settings. 
# By using environment variables, you can keep sensitive information out of your codebase and easily switch configurations without changing the code.
# -----// EXAMPLES //-----
# API_KEY=your_api_key_here
# DATABASE_URL=postgresql://user:password@localhost:5432/mydb
# SECRET_KEY=your_secret_key_here
# Server configuration variables:
#   PORT=4000
# API_VERSION=v1
# API_PREFIX=/api/v1
# Email settings for nodemailer:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
# Security Keys and Settings:
#   JWT_SECRET=change_this_to_a_long_random_string
#   RATE_LIMIT_WINDOW_MS=900000
#   RATE_LIMIT_MAX=100
# CORS_ORIGINS=http://localhost:5173,https://abdulwasiu.dev
# Urls that change depending on envirnonment:
#   VITE_API_BASE_URL=http://localhost:4000/api/v1
#   VITE_SITE_URL=http://localhost:5173
# Feture Flags:
#   FEATURE_X_ENABLED=true
# Third party service endpoints:
#   PAYMENT_GATEWAY_URL=https://api.paymentgateway.com/v1

# so the rule is if it might change or it's sensitive put it in .env file and access it via process.env in the code.

# Quick reflection on the .env file:
# 1. They keep secrets safe 
# 2. They make confiiguration easy and flexible to manage across different environments
# 3. They help avoid hardcoding values in the codebase, which can lead to security risks and maintenance issues.

# This .env.example file serves as a template for the actual .env file that will be used in the project.
# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
APP_NAME=abdulwasiu-portfolio

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:4000/api/v1
VITE_SITE_URL=http://localhost:5173

# ── Backend ───────────────────────────────────────────────────────────────────
PORT=4000
API_VERSION=v1
API_PREFIX=/api/v1

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/portfolio_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=portfolio_db

# ── Email (Nodemailer) ────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.fi
SMTP_PASS=your-app-password
CONTACT_EMAIL_TO=abdulwasiu@example.fi

# ── Security ─────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
CORS_ORIGINS=http://localhost:5173,https://abdulwasiu.dev
