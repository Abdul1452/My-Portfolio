# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_VERSION=v1
API_PREFIX=/api/v1

# ── Database (Prisma) ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/portfolio_db

# ── Email ─────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@email.fi
SMTP_PASS=your-app-password
CONTACT_EMAIL_TO=abdulwasiu@example.fi
CONTACT_EMAIL_FROM="Abdulwasiu Portfolio <noreply@abdulwasiu.dev>"

# ── Security ─────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_at_least_32_chars
CORS_ORIGINS=http://localhost:5173

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
